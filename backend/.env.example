# Copy this file to .env and fill in your values

# ESP32 Configuration (used only if ESP32 connects as WS client)
ESP32_IP=192.168.1.100
ESP32_PORT=81

# Camera (0 = built-in webcam, 1 = first USB webcam)
CAMERA_INDEX=0

# AI Detection
# If best.pt does not exist, falls back to COCO pretrained yolov8n.pt
MODEL_PATH=models/best.pt
CONFIDENCE_THRESHOLD=0.65

# Admin Credentials — CHANGE THESE BEFORE DEPLOYMENT
ADMIN_USERNAME=admin
ADMIN_PASSWORD=EcoSwap2024!

# JWT — generate a strong random secret for production
JWT_SECRET=change-this-to-a-long-random-secret-string

# Server
HOST=0.0.0.0
PORT=8000
